{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run vercel:build",
  "installCommand": "npm install --legacy-peer-deps",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/admin", "destination": "/api/index" },
    { "source": "/admin/:path*", "destination": "/api/index" }
  ],
  "crons": [
    {
      "path": "/api/cron/fire-reminders",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/auto-save",
      "schedule": "0 14 * * 5"
    },
    {
      "path": "/api/cron/protections",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/cron/notify",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/cron/patterns",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/distill-memories",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/rewrite-dossiers",
      "schedule": "30 3 * * *"
    }
  ]
}
